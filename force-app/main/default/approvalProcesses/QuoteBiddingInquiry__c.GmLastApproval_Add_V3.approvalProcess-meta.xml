    <emailTemplate>unfiled$public/QuoteBiddingApprovalRequest</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <formula>OR(
    AND(
        RecordType.DeveloperName= &quot;O&quot;,
        OR(
            AND(ISPICKVAL(PublicOrPrivateDemand__c, &quot;官需&quot;), ISPICKVAL(PrimeSubContractor__c, &quot;元請&quot;)), 
            AND(ISPICKVAL(PublicOrPrivateDemand__c, &quot;官需&quot;), ISPICKVAL(PrimeSubContractor__c, &quot;下請&quot;), OrderTransactionDetailCount__c &lt; 1)
        ),
        Refusal__c=FALSE,
        SpecialInprofitProject__c=FALSE,
        FreeContract__c=TRUE,
        OR(
            AND(NOT(ISPICKVAL(BidForm__c, &quot;JV&quot;)),ABS(PriceProposal1CP__c) &gt;= 100000000),
            AND(ISPICKVAL(BidForm__c, &quot;JV&quot;),ABS(JvBiddingPriceProposal__c) &gt;= 100000000)
        ),
        AdditionalPostInquiryApplication__c = true
    ),
    AND(
        RecordType.DeveloperName= &quot;O&quot;,
        OR(
            ISPICKVAL(PublicOrPrivateDemand__c, &quot;民需&quot;),
            AND(ISPICKVAL(PublicOrPrivateDemand__c, &quot;官需&quot;), ISPICKVAL(PrimeSubContractor__c, &quot;下請&quot;), OrderTransactionDetailCount__c &gt;= 1)
        ),
        SpecialInprofitProject__c=FALSE,
        OR(
            AND(NOT(ISPICKVAL(BidForm__c, &quot;JV&quot;)),ABS(PriceProposal1CP__c) &gt;= 100000000),
            AND(ISPICKVAL(BidForm__c, &quot;JV&quot;),ABS(JvBiddingPriceProposal__c) &gt;= 100000000)
        ),
        AdditionalPostInquiryApplication__c = true
    ),
    AND(
        RecordType.DeveloperName= &quot;SH&quot;,
        OR(
            AND(NOT(ISPICKVAL(BidForm__c, &quot;JV&quot;)),ABS(AdjustCPMax__c) &gt;= 100000000),
            AND(ISPICKVAL(BidForm__c, &quot;JV&quot;),ABS(JvBiddingPriceProposal__c) &gt;= 100000000)
        ),
        AdditionalPostInquiryApplication__c = true
    ),
    AND(
        RecordType.DeveloperName= &quot;FeeInquiry&quot;,
        OR(SpecialOrGeneral_MAX__c=&quot;特別&quot;, SpecialOrGeneral_MIN__c=&quot;特別&quot;),
        AdditionalPostInquiryApplication__c = true
    )
)</formula>
