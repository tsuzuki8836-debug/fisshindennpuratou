<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>FinalApproveNotificationEmailText__c</fullName>
    <externalId>false</externalId>
    <formula>IF (
      AND(
              ISPICKVAL(RequestClassification__c , &quot;伺い申請&quot;),
              OR(
	    	    RecordType.DeveloperName = &apos;O&apos;,
	    	    RecordType.DeveloperName = &apos;SH&apos;
                  ) 
            ),
      &quot;結果が判りましたら、速やかに報告WFの申請をお願いします。&quot; , 
      &quot;ご確認をお願いします。&quot;
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>最終承認通知メール本文</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
