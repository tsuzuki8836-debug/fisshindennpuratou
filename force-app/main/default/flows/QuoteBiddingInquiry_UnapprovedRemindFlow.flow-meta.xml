    <recordLookups>
        <description>アラート対象の割当先情報を取得する。</description>
        <name>get_ActorUser</name>
        <label>アクター取得（ユーザ）</label>
        <locationX>264</locationX>
        <locationY>600</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>get_ActorQueueId</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
