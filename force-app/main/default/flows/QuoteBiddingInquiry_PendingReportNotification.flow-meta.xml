<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <description>レコード所有者に結果未報告アラートメールを送信する</description>
        <name>SendPendingAlertMail</name>
        <label>結果未報告アラートメール送信</label>
        <locationX>138</locationX>
        <locationY>792</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <connector>
            <targetReference>ResetSendAddressList</targetReference>
        </connector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>emailAddressesArray</name>
            <value>
                <elementReference>var_Addresses</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailSubject</name>
            <value>
                <elementReference>var_MailSubject</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailBody</name>
            <value>
                <elementReference>var_MailText</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>sendRichBody</name>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
    </actionCalls>
    <apiVersion>62.0</apiVersion>
    <assignments>
        <name>ResetSendAddressList</name>
        <label>送信者リストリセット</label>
        <locationX>138</locationX>
        <locationY>900</locationY>
        <assignmentItems>
            <assignToReference>var_Addresses</assignToReference>
            <operator>RemoveAll</operator>
            <value>
                <elementReference>loopQuoteBiddingInquiryList.Owner:User.Email</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>loopQuoteBiddingInquiryList</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>SetOwnerToMailList</name>
        <label>レコード所有者を宛先に追加する</label>
        <locationX>138</locationX>
        <locationY>684</locationY>
        <assignmentItems>
            <assignToReference>var_Addresses</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>loopQuoteBiddingInquiryList.Owner:User.Email</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>SendPendingAlertMail</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>isExistTargetRecord</name>
        <label>処理対象が存在するか</label>
        <locationX>182</locationX>
        <locationY>468</locationY>
        <defaultConnectorLabel>取得効果がない</defaultConnectorLabel>
        <rules>
            <name>isExist</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>getTargetRecords</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>loopQuoteBiddingInquiryList</targetReference>
            </connector>
            <label>取得効果がある</label>
        </rules>
    </decisions>
    <decisions>
        <name>JudgeDate</name>
        <label>通知日を判定</label>
        <locationX>380</locationX>
        <locationY>252</locationY>
        <defaultConnectorLabel>通知日ではない</defaultConnectorLabel>
        <rules>
            <name>isNoticeDate</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NoticeDate</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>getTargetRecords</targetReference>
            </connector>
            <label>通知日</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>NoticeDate</name>
        <dataType>Boolean</dataType>
        <expression>DAY(TODAY()) = 1</expression>
    </formulas>
    <formulas>
        <name>OneMonthsAgoDate</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS(TODAY(), -1)</expression>
    </formulas>
    <formulas>
        <name>ThreeMonthsAgoDate</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS(TODAY(), -3)</expression>
    </formulas>
    <formulas>
        <name>var_MailSubject</name>
        <dataType>String</dataType>
        <expression>&quot;未報告アラート「&quot;+ {!loopQuoteBiddingInquiryList.Name} + &quot;」&quot;</expression>
    </formulas>
    <formulas>
        <name>var_RecordPageURL</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_560}  ,FIND(&quot;/services/Soap/&quot;, {!$Api.Partner_Server_URL_560})) + &apos;lightning/r/QuoteBiddingInquiry__c/&apos; + {!loopQuoteBiddingInquiryList.Id} + &apos;/view&apos;</expression>
    </formulas>
    <interviewLabel>未報告伺いの結果報告アラート通知 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>未報告伺いの結果報告アラート通知</label>
    <loops>
        <name>loopQuoteBiddingInquiryList</name>
        <label>処理対象レコードリストをループ</label>
        <locationX>50</locationX>
        <locationY>576</locationY>
        <collectionReference>getTargetRecords</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>SetOwnerToMailList</targetReference>
        </nextValueConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>getTargetRecords</name>
        <label>処理対象の見積・応札伺いを取得</label>
        <locationX>182</locationX>
        <locationY>360</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>isExistTargetRecord</targetReference>
        </connector>
        <filterLogic>((1 OR 8) AND 2 AND 3 AND 5 AND 7) OR ((1 OR 8) AND 2 AND 4 AND 6 AND 7)</filterLogic>
        <filters>
            <field>ResultContactStatus__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>未申請</stringValue>
            </value>
        </filters>
        <filters>
            <field>InquiryApprovalDate__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>BidCheck__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>BidCheck__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>BidOpeningDay__c</field>
            <operator>LessThan</operator>
            <value>
                <elementReference>OneMonthsAgoDate</elementReference>
            </value>
        </filters>
        <filters>
            <field>InquiryApprovalDate__c</field>
            <operator>LessThan</operator>
            <value>
                <elementReference>ThreeMonthsAgoDate</elementReference>
            </value>
        </filters>
        <filters>
            <field>RequestClassification__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>結果報告</stringValue>
            </value>
        </filters>
        <filters>
            <field>ResultContactStatus__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>QuoteBiddingInquiry__c</object>
        <sortField>CreatedDate</sortField>
        <sortOrder>Asc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>254</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>JudgeDate</targetReference>
        </connector>
        <schedule>
            <frequency>Daily</frequency>
            <startDate>2024-11-26</startDate>
            <startTime>08:30:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>var_MailText</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>以下の伺いの結果が未報告です
結果が判り次第、速やかに結果報告WFの申請をお願いします。

伺い件名：
{!loopQuoteBiddingInquiryList.Name}

伺い区分：
{!loopQuoteBiddingInquiryList.RecordType.Name}

詳細リンク：
{!var_RecordPageURL}</text>
    </textTemplates>
    <variables>
        <name>var_Addresses</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
