<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>プロセスビルダー「納期管理自動設定」から移行</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_ApproveDate1</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS({!$Record.Factory__r.CarryingDay__c},
-(VALUE(TEXT({!$Record.Term_Month__c}) ) ) )</expression>
    </formulas>
    <formulas>
        <name>formula_IssueDate1</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS(ADDMONTHS({!$Record.Factory__r.CarryingDay__c} ,-(VALUE((TEXT({!$Record.Term_Month__c}))))),-1)</expression>
    </formulas>
    <formulas>
        <name>formula_OnSiteWitness1</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Factory__r.CarryingDay__c} - 14</expression>
    </formulas>
    <formulas>
        <name>formula_OnSiteWitnessPlanningDate1</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Factory__r.CarryingDay__c}  + 5</expression>
    </formulas>
    <interviewLabel>【納期管理】新規作成時に場所別項目転記 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>【納期管理】新規作成時に場所別項目転記</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>場所別から初期値を設定する</description>
        <name>updateFromFactory</name>
        <label>新規作成時自動設定</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>ApproveDate1__c</field>
            <value>
                <elementReference>formula_ApproveDate1</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>CarryingDate1__c</field>
            <value>
                <elementReference>$Record.Factory__r.CarryingDay__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>EquipmentDeliverytime__c</field>
            <value>
                <elementReference>$Record.Factory__r.CarryingDay__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Factory01__c</field>
            <value>
                <elementReference>$Record.Factory__r.Factory__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>IssueDate1__c</field>
            <value>
                <elementReference>formula_IssueDate1</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OnSiteWitness1__c</field>
            <value>
                <elementReference>formula_OnSiteWitness1</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OnSiteWitnessPlanningDate1__c</field>
            <value>
                <elementReference>formula_OnSiteWitnessPlanningDate1</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Opportunity32__c</field>
            <value>
                <elementReference>$Record.Factory__r.Opp1__r.Id</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>updateFromFactory</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Factory__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>DeliveryManagement__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
