<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>ワークフロールール「【ユーザ】案件初期値用BU転記」から移行</description>
    <environments>Default</environments>
    <formulas>
        <name>transcriptionBUFormulaFormula</name>
        <dataType>String</dataType>
        <expression>TEXT($Record.BU__c)</expression>
    </formulas>
    <interviewLabel>【ユーザ】案件初期値用BU転記 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>【ユーザ】案件初期値用BU転記</label>
    <migratedFromWorkflowRuleName>【ユーザ】案件初期値用BU転記</migratedFromWorkflowRuleName>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>updateBUFormula</name>
        <label>BUを転記</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>BUFormula__c</field>
            <value>
                <elementReference>transcriptionBUFormulaFormula</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>updateBUFormula</targetReference>
        </connector>
        <object>User</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
