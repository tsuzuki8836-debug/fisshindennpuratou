    <decisions>
        <name>checkListSizeOver30</name>
        <label>リストのサイズが30以上か判定</label>
        <locationX>534</locationX>
        <locationY>1176</locationY>
        <defaultConnector>
            <targetReference>clearList</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>リストのサイズが30以上</defaultConnectorLabel>
        <rules>
            <name>isListSizeUnder30</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>listSizeCounter</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>30.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assignRequestTask1To30</targetReference>
            </connector>
            <label>リストのサイズが30未満</label>
        </rules>
    </decisions>
    <decisions>
        <name>isExistTargetRecord</name>
        <label>処理対象が存在するか</label>
        <locationX>314</locationX>
        <locationY>360</locationY>
        <defaultConnector>
            <targetReference>isTargetRequestTaskOver120</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>取得結果がない</defaultConnectorLabel>
        <rules>
            <name>isExist</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>getTargetRecords</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assignRecordNumberToVariable</targetReference>
            </connector>
            <label>取得結果がある</label>
        </rules>
    </decisions>
    <decisions>
        <description>処理対象レコード総数が120を超えているかを判定する。
120件を超過している場合はCRM事務局宛てにChatter投稿する。</description>
        <name>isTargetRequestTaskOver120</name>
        <label>処理対象レコード総数が120を超えているか</label>
        <locationX>314</locationX>
        <locationY>768</locationY>
        <defaultConnector>
            <targetReference>loopTargetRequestTaskListForSplit</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>120件未満である</defaultConnectorLabel>
        <rules>
            <name>isOver120</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>targetRequestTaskCount</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>120.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>alertToCrmAdminGroup</targetReference>
            </connector>
            <label>120件を超過している</label>
        </rules>
        <rules>
            <name>is0</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>targetRequestTaskCount</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <label>0件である</label>
        </rules>
    </decisions>
