<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>プロセスビルダー「機器仕様自動設定」から移行</description>
    <environments>Default</environments>
    <interviewLabel>【機器仕様】新規作成時に場所別項目転記 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>【機器仕様】新規作成時に場所別項目転記</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>場所別から初期値を設定する</description>
        <name>updateFromFactory</name>
        <label>新規作成時自動設定</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>EquipmentDeliveryTime__c</field>
            <value>
                <elementReference>$Record.Factorys__r.CarryingDay__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>FactoryRelationNo__c</field>
            <value>
                <elementReference>$Record.Factorys__r.CopyBaseNo_txt__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Opp5__c</field>
            <value>
                <elementReference>$Record.Factorys__r.Opp1__r.Id</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>updateFromFactory</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Factorys__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>ProductSpecification__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
