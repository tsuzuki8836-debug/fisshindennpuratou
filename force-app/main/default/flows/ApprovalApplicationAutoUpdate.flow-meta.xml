    </formulas>
    <formulas>
        <name>quoteBuRoleFormula</name>
        <dataType>String</dataType>
        <expression>IF( ISPICKVAL( {!$Record.BU__c}, &quot;施設&quot;), &quot;ファシリティインフラシステム事業部 施設環境部&quot;,
    IF( ISPICKVAL( {!$Record.BU__c}, &quot;水環境&quot;), &quot;ファシリティインフラシステム事業部 社会システム第一部&quot;,
        IF( ISPICKVAL( {!$Record.BU__c}, &quot;官需&quot;), &quot;ファシリティインフラシステム事業部 社会システム第二部&quot;,
            IF( ISPICKVAL( {!$Record.BU__c}, &quot;官公情報&quot;), &quot;ファシリティインフラシステム事業部 官公システム部&quot;,
              IF( ISPICKVAL( {!$Record.BU__c}, &quot;通シ&quot;), &quot;ファシリティインフラシステム事業部 通信システム部&quot;,
              &quot;&quot;)
          )
        )
    )
)</expression>
    </formulas>
    <formulas>
        <description>ReportDetail__cの改行を「&lt;br&gt;・」に置換し、本文を改行する。</description>
        <name>ReplaceReportDetail</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE({!$Record.ReportDetail__c}, SUBSTITUTE($Label.LineBreak, &quot;-&quot;, &quot;&quot;), &quot;&lt;br&gt;&quot;)</expression>
    </formulas>
    <formulas>
        <name>resultStatusCorrectionValue</name>
        <dataType>String</dataType>
        <expression>IF(
    AND(
        ISPICKVAL({!$Record.ResultContactStatus__c},&apos;TL&apos;), 
        ISBLANK({!$Record.TLApprover__c})
    ),
    &apos;所属課長&apos;,TEXT({!$Record.ResultContactStatus__c})
)</expression>
    </formulas>
    <formulas>
        <name>var_RecordPageURL</name>
        <dataType>String</dataType>
        <expression>LEFT($Api.Partner_Server_URL_560  ,FIND(&quot;/services/Soap/&quot;, $Api.Partner_Server_URL_560)) + &apos;lightning/r/QuoteBiddingInquiry__c/&apos; + {!$Record.Id} + &apos;/view&apos;</expression>
    </formulas>
