    <formulas>
        <name>inquiryStatusCorrectionValue</name>
        <dataType>String</dataType>
        <expression>IF(
    AND(
        ISPICKVAL({!$Record.InquiryApprovalStatus__c},&apos;TL&apos;), 
        ISBLANK({!$Record.TLApprover__c})
    ),
    &apos;所属課長&apos;,TEXT({!$Record.InquiryApprovalStatus__c})
)</expression>
    </formulas>
    <formulas>
        <description>送信するメールの件名。</description>
        <name>MailSubject</name>
