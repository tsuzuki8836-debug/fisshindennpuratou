<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>プロセスビルダー「一般管理費コピー」から移行</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_GeneralAdministrativeExpenses</name>
        <dataType>Number</dataType>
        <expression>VALUE({!$Record.GeneralAdministrativeExpenses__c} ) * 1</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>formula_TextDivision</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.Opportunity__r.PickDivision__c} )</expression>
    </formulas>
    <interviewLabel>【見積】案件部門コピー {!$Flow.CurrentDateTime}</interviewLabel>
    <label>【見積】案件部門コピー</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>updateDivision</name>
        <label>案件.部門を部門に転記</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>PickDivision__c</field>
            <value>
                <elementReference>$Record.Opportunity__r.PickDivision__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>TextDivision__c</field>
            <value>
                <elementReference>formula_TextDivision</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>updateDivision</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Opportunity__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Quote__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
