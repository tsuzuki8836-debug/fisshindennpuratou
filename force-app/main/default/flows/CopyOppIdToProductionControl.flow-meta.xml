<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <description>場所別の案件変更時に、関連する生産管理の案件を合わせて更新する</description>
    <environments>Default</environments>
    <interviewLabel>場所別の案件を生産管理にコピーする {!$Flow.CurrentDateTime}</interviewLabel>
    <label>場所別の案件を生産管理にコピーする</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>場所別の案件IDを生産管理の案件IDにコピーする</description>
        <name>UpdateProductionControl</name>
        <label>生産管理の案件ID更新</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <inputAssignments>
            <field>Opportunity__c</field>
            <value>
                <elementReference>$Record.Opp1__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record.ProductionControls__r</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>UpdateProductionControl</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Opp1__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Factory__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
